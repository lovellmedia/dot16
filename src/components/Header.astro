---
export interface Props {
  title?: string;
}

const { title = "Dot16" } = Astro.props;
const topicSlug = "vehicle-acoustic-engineering";
---

<nav>
  <div class="container">
    <a href="/" class="logo">{title}</a>
    <button class="mobile-menu-toggle" onclick="toggleMenu()" aria-label="Toggle menu">☰</button>
    <ul id="nav-menu">
      <li><a href="/">Home</a></li>
      <li><a href={`/${topicSlug}/`}>Overview</a></li>
      <li><a href={`/${topicSlug}/history/`}>History</a></li>
      <li><a href={`/${topicSlug}/technical-deep-dive/`}>Technical</a></li>
      <li><a href={`/${topicSlug}/ontology/`}>Ontology</a></li>
      <li><a href={`/${topicSlug}/trends/`}>Trends</a></li>
      <li><a href={`/${topicSlug}/tools/`}>Tools</a></li>
      <li><a href={`/${topicSlug}/challenges/`}>Challenges</a></li>
    </ul>
  </div>
</nav>

<script is:inline>
  function toggleMenu() {
    const menu = document.getElementById('nav-menu');
    menu.classList.toggle('active');
  }
</script>
