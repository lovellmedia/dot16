---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string;
  description?: string;
  topic?: string;
  pillar?: string;
  keyPoints?: string[];
}

const { 
  title, 
  description = "Technical research on vehicle acoustic engineering", 
  topic = "Vehicle Acoustic Engineering",
  pillar = "",
  keyPoints = []
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header slot="header" title="Dot16" />
  <Navigation currentTopic={topic} currentPillar={pillar} />
  
  <section class="topic-content">
    <div class="container">
      <div class="academic-columns">
        <div class="main-content">
          <slot />
        </div>
        <Sidebar keyPoints={keyPoints} />
      </div>
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .topic-content {
    padding: 3rem;
    background: #fdfcfa;
  }

  .topic-content .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .academic-columns {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
  }

  .main-content h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 2rem;
    line-height: 1.3;
  }

  @media (max-width: 968px) {
    .topic-content {
      padding: 2rem 1.5rem;
    }

    .academic-columns {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .main-content h1 {
      font-size: 1.8rem;
    }
  }
</style>
