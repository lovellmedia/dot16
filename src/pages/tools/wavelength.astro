---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout 
  title="Wavelength Calculator - Dot16"
  description="Convert audio frequency to wavelength and vice versa for acoustic calculations."
>
  <Header slot="header" title="Dot16" />
  
  <section class="tool-page">
    <div class="container">
      <h1>Wavelength Calculator</h1>
      <p class="intro">
        Calculate the wavelength of sound at a given frequency, or determine the frequency for a given wavelength. 
        This relationship is fundamental to understanding room modes, boundary effects, and acoustic treatment design.
      </p>

      <div class="calculator">
        <div class="calc-mode">
          <label>
            <input type="radio" name="mode" value="freqToWave" checked onchange="toggleMode()">
            Frequency to Wavelength
          </label>
          <label>
            <input type="radio" name="mode" value="waveToFreq" onchange="toggleMode()">
            Wavelength to Frequency
          </label>
        </div>

        <div id="freqInput" class="input-section">
          <div class="input-group">
            <label for="frequency">Frequency</label>
            <div class="input-with-unit">
              <input type="number" id="frequency" step="1" placeholder="100" value="100">
              <span class="unit">Hz</span>
            </div>
          </div>
        </div>

        <div id="waveInput" class="input-section hidden">
          <div class="input-group">
            <label for="wavelength">Wavelength</label>
            <div class="input-with-unit">
              <input type="number" id="wavelength" step="0.01" placeholder="3.43">
              <select id="waveUnit">
                <option value="m">meters</option>
                <option value="ft">feet</option>
                <option value="cm">cm</option>
                <option value="in">inches</option>
              </select>
            </div>
          </div>
        </div>

        <div class="input-group">
          <label for="temperature">Air Temperature</label>
          <div class="input-with-unit">
            <input type="number" id="temperature" step="1" value="20">
            <select id="tempUnit">
              <option value="C">°C</option>
              <option value="F">°F</option>
            </select>
          </div>
        </div>

        <button onclick="calculate()" class="calculate-btn">Calculate</button>

        <div id="results" class="results hidden">
          <h3>Results</h3>
          <div class="result-grid">
            <div class="result-item">
              <span class="result-label">Wavelength:</span>
              <span class="result-value" id="resultWave">-</span>
            </div>
            <div class="result-item">
              <span class="result-label">Frequency:</span>
              <span class="result-value" id="resultFreq">-</span>
            </div>
            <div class="result-item">
              <span class="result-label">Speed of Sound:</span>
              <span class="result-value" id="resultSpeed">-</span>
            </div>
            <div class="result-item">
              <span class="result-label">Period:</span>
              <span class="result-value" id="resultPeriod">-</span>
            </div>
          </div>
        </div>
      </div>

      <div class="reference-table">
        <h3>Common Frequencies Reference</h3>
        <table>
          <thead>
            <tr>
              <th>Frequency</th>
              <th>Wavelength</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>20 Hz</td><td>17.15 m (56.3 ft)</td><td>Lowest audible frequency</td></tr>
            <tr><td>40 Hz</td><td>8.58 m (28.1 ft)</td><td>Low E string on bass guitar</td></tr>
            <tr><td>80 Hz</td><td>4.29 m (14.1 ft)</td><td>Typical subwoofer crossover</td></tr>
            <tr><td>100 Hz</td><td>3.43 m (11.3 ft)</td><td>Deep bass range</td></tr>
            <tr><td>200 Hz</td><td>1.72 m (5.6 ft)</td><td>Upper bass / lower mids</td></tr>
            <tr><td>500 Hz</td><td>68.6 cm (2.3 ft)</td><td>Midrange frequencies</td></tr>
            <tr><td>1000 Hz</td><td>34.3 cm (1.1 ft)</td><td>Reference frequency</td></tr>
            <tr><td>5000 Hz</td><td>6.9 cm (2.7 in)</td><td>Speech clarity range</td></tr>
            <tr><td>10000 Hz</td><td>3.4 cm (1.3 in)</td><td>High frequency treble</td></tr>
            <tr><td>20000 Hz</td><td>1.7 cm (0.7 in)</td><td>Upper hearing limit</td></tr>
          </tbody>
        </table>
      </div>

      <div class="formula-info">
        <h3>Formula</h3>
        <code>λ = c / f</code>
        <p>Where:</p>
        <ul>
          <li><strong>λ (lambda)</strong> = wavelength (meters)</li>
          <li><strong>c</strong> = speed of sound (m/s)</li>
          <li><strong>f</strong> = frequency (Hz)</li>
        </ul>
        <p>The speed of sound in air varies with temperature:</p>
        <code>c = 331.3 + (0.606 × T)</code>
        <p>Where T is temperature in °C. At 20°C, c ≈ 343 m/s (1125 ft/s).</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script is:inline>
  function toggleMode() {
    const mode = document.querySelector('input[name="mode"]:checked').value;
    if (mode === 'freqToWave') {
      document.getElementById('freqInput').classList.remove('hidden');
      document.getElementById('waveInput').classList.add('hidden');
    } else {
      document.getElementById('freqInput').classList.add('hidden');
      document.getElementById('waveInput').classList.remove('hidden');
    }
    document.getElementById('results').classList.add('hidden');
  }

  function calculate() {
    const mode = document.querySelector('input[name="mode"]:checked').value;
    const temp = parseFloat(document.getElementById('temperature').value);
    const tempUnit = document.getElementById('tempUnit').value;

    // Calculate speed of sound
    let tempC = temp;
    if (tempUnit === 'F') {
      tempC = (temp - 32) * 5/9;
    }
    const c = 331.3 + (0.606 * tempC); // m/s
    const cFt = c * 3.28084;

    let frequency, wavelength;

    if (mode === 'freqToWave') {
      frequency = parseFloat(document.getElementById('frequency').value);
      if (!frequency || frequency <= 0) {
        alert('Please enter a valid frequency');
        return;
      }
      wavelength = c / frequency;
    } else {
      wavelength = parseFloat(document.getElementById('wavelength').value);
      const waveUnit = document.getElementById('waveUnit').value;
      
      if (!wavelength || wavelength <= 0) {
        alert('Please enter a valid wavelength');
        return;
      }
      
      // Convert to meters
      let waveM = wavelength;
      if (waveUnit === 'ft') waveM = wavelength * 0.3048;
      else if (waveUnit === 'cm') waveM = wavelength / 100;
      else if (waveUnit === 'in') waveM = wavelength * 0.0254;
      
      wavelength = waveM;
      frequency = c / wavelength;
    }

    // Calculate period
    const period = 1 / frequency;

    // Display results
    document.getElementById('resultWave').innerHTML = 
      `${wavelength.toFixed(2)} m (${(wavelength * 3.28084).toFixed(2)} ft)`;
    document.getElementById('resultFreq').innerHTML = 
      `${frequency.toFixed(1)} Hz`;
    document.getElementById('resultSpeed').innerHTML = 
      `${c.toFixed(0)} m/s (${cFt.toFixed(0)} ft/s)`;
    document.getElementById('resultPeriod').innerHTML = 
      `${(period * 1000).toFixed(2)} ms`;

    document.getElementById('results').classList.remove('hidden');
  }
</script>

<style>
  .tool-page {
    padding: 3rem;
    background: #fdfcfa;
    min-height: calc(100vh - 200px);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    color: #1a1a1a;
    margin-bottom: 1rem;
    font-family: 'Crimson Text', Georgia, serif;
  }

  .intro {
    font-size: 1.1rem;
    color: #5a5a5a;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .calculator {
    background: #ffffff;
    padding: 2.5rem;
    border: 1px solid #e8e6e0;
    margin-bottom: 2rem;
  }

  .calc-mode {
    display: flex;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .calc-mode label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Lato', sans-serif;
    cursor: pointer;
  }

  .calc-mode input {
    cursor: pointer;
  }

  .input-section.hidden {
    display: none;
  }

  .input-group {
    margin-bottom: 1.5rem;
  }

  .input-group label {
    display: block;
    font-family: 'Lato', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: #2b2b2b;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .input-with-unit {
    display: flex;
    gap: 0.5rem;
  }

  .input-with-unit input {
    flex: 1;
    padding: 0.75rem;
    border: 1px solid #d4d0c8;
    font-size: 1rem;
    font-family: 'Crimson Text', Georgia, serif;
  }

  .input-with-unit .unit,
  .input-with-unit select {
    padding: 0.75rem;
    border: 1px solid #d4d0c8;
    background: #f8f7f5;
    font-family: 'Lato', sans-serif;
    font-size: 0.9rem;
    min-width: 100px;
  }

  .calculate-btn {
    background: #2b2b2b;
    color: #ffffff;
    padding: 1rem 2rem;
    border: none;
    font-family: 'Lato', sans-serif;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s;
    width: 100%;
  }

  .calculate-btn:hover {
    background: #4a4a4a;
  }

  .results {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 2px solid #e8e6e0;
  }

  .results.hidden {
    display: none;
  }

  .results h3 {
    font-size: 1.3rem;
    color: #1a1a1a;
    margin-bottom: 1rem;
    font-family: 'Crimson Text', Georgia, serif;
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .result-item {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    background: #f8f7f5;
    border-left: 3px solid #2b5a8c;
  }

  .result-label {
    color: #5a5a5a;
    font-family: 'Lato', sans-serif;
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .result-value {
    font-weight: 600;
    color: #1a1a1a;
    font-size: 1.1rem;
  }

  .reference-table {
    background: #ffffff;
    padding: 2rem;
    border: 1px solid #e8e6e0;
    margin-bottom: 2rem;
    overflow-x: auto;
  }

  .reference-table h3 {
    font-size: 1.3rem;
    color: #1a1a1a;
    margin-bottom: 1rem;
    font-family: 'Crimson Text', Georgia, serif;
  }

  .reference-table table {
    width: 100%;
    border-collapse: collapse;
  }

  .reference-table th {
    background: #f8f7f5;
    padding: 0.75rem;
    text-align: left;
    font-family: 'Lato', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid #2b2b2b;
  }

  .reference-table td {
    padding: 0.75rem;
    border-bottom: 1px solid #e8e6e0;
    font-size: 0.95rem;
  }

  .formula-info {
    background: #f8f7f5;
    padding: 2rem;
    border: 1px solid #e8e6e0;
  }

  .formula-info h3 {
    font-size: 1.3rem;
    color: #1a1a1a;
    margin-bottom: 1rem;
    font-family: 'Crimson Text', Georgia, serif;
  }

  .formula-info code {
    display: block;
    background: #ffffff;
    padding: 1rem;
    font-family: 'Courier New', monospace;
    font-size: 1.1rem;
    border: 1px solid #d4d0c8;
    margin: 1rem 0;
  }

  .formula-info ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .formula-info li {
    margin-bottom: 0.5rem;
    color: #4a4a4a;
  }

  @media (max-width: 768px) {
    .tool-page {
      padding: 2rem 1.5rem;
    }

    h1 {
      font-size: 1.8rem;
    }

    .calculator {
      padding: 1.5rem;
    }

    .calc-mode {
      flex-direction: column;
      gap: 0.75rem;
    }

    .result-grid {
      grid-template-columns: 1fr;
    }

    .reference-table {
      padding: 1rem;
    }
  }
</style>
