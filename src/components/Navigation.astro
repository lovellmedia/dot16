---
export interface Props {
  currentTopic?: string;
  currentPillar?: string;
}

const { currentTopic = "Vehicle Acoustic Engineering", currentPillar = "" } = Astro.props;
const topicSlug = "vehicle-acoustic-engineering";
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <div class="container">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href={`/${topicSlug}/`}>{currentTopic}</a></li>
      {currentPillar && <li aria-current="page">{currentPillar}</li>}
    </ol>
  </div>
</nav>

<style>
  .breadcrumbs {
    background: #f8f7f5;
    padding: 1rem 0;
    border-bottom: 1px solid #e8e6e0;
  }

  .breadcrumbs .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .breadcrumbs ol {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Lato', sans-serif;
    font-size: 0.9rem;
  }

  .breadcrumbs li {
    color: #5a5a5a;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: "/";
    margin-left: 0.5rem;
    color: #a8a8a8;
  }

  .breadcrumbs li[aria-current="page"] {
    color: #2b2b2b;
    font-weight: 600;
  }

  .breadcrumbs a {
    color: #2b5a8c;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .breadcrumbs .container {
      padding: 0 1.5rem;
    }
  }
</style>
